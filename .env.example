# Pandoravirus 2.0 — environment variables template
#
# Copy to `.env` and fill in your local Postgres password.
# Both `.env` and `*.env` are in .gitignore so this file will not be tracked.
#
# All scripts in scripts/ read these via os.environ.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pandoravirus
DB_USER=postgres
DB_PASSWORD=your-local-postgres-password-here
